    "settings.storage.clear_album_art" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Albumcover löschen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clear Album Art"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Effacer les pochettes"
          }
        }
      }
    },
    "settings.storage.clear_album_art.message" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden alle zwischengespeicherten Albumcover gelöscht. Cover geladener Alben bleiben erhalten. Albumcover werden beim Durchsuchen erneut geladen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will clear all cached album art. Art for downloaded albums will be kept. Album art will be re-downloaded as you browse."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela effacera toutes les pochettes en cache. Les pochettes des albums téléchargés seront conservées. Elles seront téléchargées à nouveau lors de la navigation."
          }
        }
      }
    },
    "settings.storage.clear_cache" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cache leeren"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clear Cache"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vider le cache"
          }
        }
      }
    },
    "settings.storage.clear_cache.message" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden alle zwischengespeicherten Songs gelöscht. Du kannst Songs erneut zwischenspeichern, indem du sie abspielst oder das Album lädst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will clear all cached songs. You can re-cache songs by playing them again or saving the album as downloaded."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela effacera toutes les chansons en cache. Vous pouvez les remettre en cache en les écoutant à nouveau ou en téléchargeant l'album."
          }
        }
      }
    },
    "settings.storage.clear_downloads" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
